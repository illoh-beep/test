<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>iPhone Test</title>
  <style>
    body {
      font-family: -apple-system, sans-serif;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      margin: 0;
      background: #1a1a2e;
      color: white;
    }
    h1 { font-size: 24px; margin-bottom: 8px; }
    p  { color: #aaa; margin-bottom: 32px; }
    button {
      background: #e94560;
      color: white;
      border: none;
      padding: 16px 32px;
      border-radius: 12px;
      font-size: 18px;
      cursor: pointer;
    }
    #result {
      margin-top: 24px;
      font-size: 22px;
      font-weight: bold;
      min-height: 40px;
    }
  </style>
</head>
<body>
  <h1>✅ HTML läuft!</h1>
  <p>Tippe den Button um zu testen</p>
  <button onclick="zähle()">Tippen!</button>
  <div id="result"></div>
  <script>
    let count = 0;
    function zähle() {
      count++;
      document.getElementById('result').textContent = '🎉 ' + count + 'x getippt!';
    }
  </script>
</body>
</html>
